# Development API URLs. Used by `npm run dev`.
VITE_LOCAL_API_BASE_URL=http://localhost:5000/api
VITE_LOCAL_API_ORIGIN=http://localhost:5000
VITE_CLIENT_URL=http://localhost:5173

# Production API URLs. Used by `npm run build`.
VITE_PRODUCTION_API_BASE_URL=https://pickupzone.org/api
VITE_PRODUCTION_API_ORIGIN=https://pickupzone.org
VITE_PRODUCTION_CLIENT_URL=https://pickupzone.org

# Legacy fallbacks. Leave empty unless you intentionally want one URL for every build mode.
VITE_API_BASE_URL=
VITE_API_ORIGIN=
